{
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git push -u origin *)",
      "Bash(git push origin *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git status)",
      "Bash(git show *)",
      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(npm run build:dev)",
      "Bash(npm run preview)",
      "Bash(npm test)",
      "Bash(npm test -- *)",
      "Bash(npx tsc *)",
      "Bash(bash scripts/verify/*.sh)",
      "Bash(node scripts/verify/*.mjs)",
      "Bash(python3 -c *)",
      "mcp__github__list_commits",
      "mcp__github__list_branches",
      "mcp__github__list_pull_requests",
      "mcp__github__list_issues",
      "mcp__github__get_commit",
      "mcp__github__get_file_contents",
      "mcp__github__search_code",
      "mcp__github__search_pull_requests",
      "mcp__github__search_issues",
      "mcp__github__pull_request_read",
      "mcp__github__issue_read",
      "mcp__github__create_branch",
      "mcp__github__create_pull_request",
      "mcp__github__push_files",
      "mcp__github__add_issue_comment",
      "mcp__github__update_pull_request",
      "mcp__vercel__listDeployments",
      "mcp__vercel__getDeployment",
      "mcp__vercel__getDeploymentLogs",
      "mcp__vercel__listProjects",
      "mcp__vercel__getProject",
      "mcp__supabase-dev__*"
    ],
    "ask": [
      "mcp__github__merge_pull_request",
      "mcp__github__delete_file",
      "Bash(git push --force *)",
      "Bash(git reset *)"
    ],
    "deny": [
      "Bash(git push --force origin main)",
      "Bash(git push --force origin master)",
      "Bash(rm -rf /*)",
      "Bash(drop table *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-check.sh",
            "async": true,
            "timeout": 15
          }
        ]
      }
    ]
  }
}
